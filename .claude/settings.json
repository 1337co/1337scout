{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "WebSearch",
      "WebFetch"
    ],
    "deny": [
      "Bash(git push --force *)",
      "Bash(git push -f *)",
      "Bash(git push --force-with-lease *)",
      "Bash(git reset --hard *)",
      "Bash(git clean -f*)",
      "Bash(git clean -d*)",
      "Bash(git checkout -- *)",
      "Bash(git restore --staged *)",
      "Bash(git restore --source *)",
      "Bash(rm -rf /)",
      "Bash(rm -rf ~)",
      "Bash(rm -rf ~/*)",
      "Bash(rm -rf .)",
      "Bash(rm -rf ./*)",
      "Bash(rm -rf ../)",
      "Bash(rm -rf ../*)",
      "Bash(rm -rf /*)",
      "Bash(rm -rf $HOME*)",
      "Bash(sudo *)",
      "Bash(chmod -R 777 *)",
      "Bash(dd if=* of=/dev/*)",
      "Bash(mkfs*)",
      "Bash(fdisk*)",
      "Bash(curl * | sh)",
      "Bash(curl * | bash)",
      "Bash(wget * | sh)",
      "Bash(wget * | bash)",
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(**/.env)",
      "Read(**/.env.*)",
      "Read(**/secrets.*)",
      "Read(**/credentials.*)",
      "Read(**/*.pem)",
      "Read(**/*.key)",
      "Read(**/id_rsa)",
      "Read(**/id_ed25519)",
      "Read(~/.aws/credentials)",
      "Read(~/.ssh/**)",
      "Read(~/.netrc)",
      "Bash(cat .env*)",
      "Bash(cat *.env*)",
      "Bash(cat ./.env*)",
      "Bash(cat **/.env*)",
      "Bash(more .env*)",
      "Bash(more *.env*)",
      "Bash(less .env*)",
      "Bash(less *.env*)",
      "Bash(head .env*)",
      "Bash(head *.env*)",
      "Bash(tail .env*)",
      "Bash(tail *.env*)",
      "Bash(grep * .env*)",
      "Bash(grep * *.env*)",
      "Bash(awk * .env*)",
      "Bash(awk * *.env*)",
      "Bash(sed * .env*)",
      "Bash(sed * *.env*)",
      "Bash(cat *.pem*)",
      "Bash(cat *.key)",
      "Bash(cat ~/.ssh/*)",
      "Bash(cat .ssh/*)",
      "Bash(cat ~/.netrc)",
      "Bash(cat .netrc)",
      "Bash(cat ~/.aws/credentials*)",
      "Bash(python -c *open*.env*)",
      "Bash(python3 -c *open*.env*)",
      "Bash(python -c *.env*)",
      "Bash(python3 -c *.env*)",
      "Bash(node -e *readFile*.env*)",
      "Bash(node -e *readFileSync*.env*)",
      "Bash(node -e *.env*)",
      "Bash(node --eval *.env*)",
      "Write(.env)",
      "Write(.env.*)",
      "Write(**/.env)",
      "Write(**/.env.*)",
      "Write(~/.aws/**)",
      "Write(~/.ssh/**)",
      "Write(~/.netrc)",
      "Edit(.env)",
      "Edit(.env.*)",
      "Edit(**/.env)",
      "Edit(**/.env.*)",
      "Edit(~/.aws/**)",
      "Edit(~/.ssh/**)",
      "MultiEdit(.env)",
      "MultiEdit(.env.*)",
      "MultiEdit(**/.env)",
      "MultiEdit(**/.env.*)",
      "MultiEdit(~/.aws/**)",
      "MultiEdit(~/.ssh/**)"
    ],
    "ask": [
      "Bash(rm -rf *)",
      "Bash(rm -r *)",
      "Bash(rm *)",
      "Bash(git push *)",
      "Bash(git commit --amend*)",
      "Bash(git rebase *)",
      "Bash(npm publish*)",
      "Bash(pip publish*)",
      "Bash(cargo publish*)",
      "Bash(gh release *)",
      "Bash(gh pr create *)",
      "Bash(docker push *)",
      "Bash(terraform apply*)",
      "Bash(terraform destroy*)",
      "Bash(kubectl delete *)",
      "Bash(kubectl apply *)",
      "Write(.claude/**)",
      "Edit(.claude/**)",
      "Write(CLAUDE.md)",
      "Edit(CLAUDE.md)",
      "Write(docs/KIT-CONSTITUTION.md)",
      "Edit(docs/KIT-CONSTITUTION.md)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume|compact",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/discipline-loader.sh",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "compact",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/compaction-recovery.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/pre-compact-backup.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/boundary-guard.sh",
            "timeout": 3
          }
        ]
      },
      {
        "matcher": "Write|Edit|MultiEdit|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/secret-scanner.sh",
            "timeout": 3
          },
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/config-protection.sh",
            "timeout": 3
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/broken-marker-gate.sh",
            "timeout": 5
          }
        ]
      }
    ]
  },
  "outputStyle": "kit-default",
  "env": {
    "CLAUDE_AUTOCOMPACT_PCT_OVERRIDE": "75",
    "CLAUDE_CODE_EFFORT_LEVEL": "xhigh"
  }
}
